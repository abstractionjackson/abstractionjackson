*.swp
*.swo
*.swn
*.log
*.tlog
*.bak
*.cache
*.sublime*
.vscode/
.idea/

# Temporary files
*.tmp
*.temp

# Node (if you're using any build tools or front-end frameworks)
node_modules/
package-lock.json
yarn.lock

# Other common directories/files to ignore
*.sass-cache/
*.backup
